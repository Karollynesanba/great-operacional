{
  "framework": "vite",
  "installCommand": "cd operacional-great && npm install --no-fund --no-audit",
  "buildCommand": "cd operacional-great && npm run build",
  "outputDirectory": "operacional-great/dist",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
